# Panacea Command Center — frontend environment
#
# The dashboard runs on simulated telemetry by default so it works with no
# backend (great for Vercel previews). Flip these when the FastAPI service is up.

# Set to "false" to consume the real backend instead of the simulator.
NEXT_PUBLIC_USE_MOCK=true

# FastAPI REST base (agent run + policy override endpoints).
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket endpoint streaming live agent reasoning tokens.
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/agent-stream

# Optional operator bearer token for privileged endpoints (manual PDF ingestion).
# Only needed when the backend runs in strict/OIDC auth mode; leave blank otherwise.
NEXT_PUBLIC_OPERATOR_TOKEN=
