# ============================================================================
# Panacea v2 — Zain module (Threat Execution & Security Infra)
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.
# ============================================================================
#
# CROSS-ACCOUNT ARCHITECTURE NOTE:
#   The target VM (Philips IntelliVue simulator) and its Vultr Cloud Firewall
#   group live on a TEAMMATE'S Vultr account, NOT mine. Whoever OWNS the
#   firewall group supplies their OWN VULTR_API_KEY + VULTR_FIREWALL_GROUP_ID
#   here and runs firewall_executor.py against their own account.
#   => The target VM's API key belongs to a teammate's account.
#      Never share it, never commit it, never hardcode it in source.
# ============================================================================

# --- Vultr auth + firewall target -------------------------------------------
# API key for the account that OWNS the firewall group being programmed.
# (Teammate's key when they run it; your key only if you own the group.)
VULTR_API_KEY=

# ID of the Vultr Cloud Firewall group to program (lives on the owner's account).
VULTR_FIREWALL_GROUP_ID=

# --- Target VM (Philips IntelliVue simulator, on teammate's account) ---------
VULTR_TARGET_INSTANCE_ID=
VULTR_TARGET_PUBLIC_IP=
VULTR_TARGET_PRIVATE_IP=
VULTR_TARGET_REGION=

# --- Attacker VM (on MY account) --------------------------------------------
VULTR_ATTACKER_INSTANCE_ID=
VULTR_ATTACKER_PUBLIC_IP=
VULTR_ATTACKER_PRIVATE_IP=

# --- Admin safety -----------------------------------------------------------
# Your own admin SSH source CIDR. The executor will NEVER delete or alter the
# firewall rule whose source matches this — it guarantees you never lock
# yourself out. Example: 203.0.113.10/32
MANAGEMENT_SSH_SOURCE_CIDR=

# --- Demo control -----------------------------------------------------------
# live = make real Vultr API calls. mock = skip API, return fallback shapes.
PANACEA_DEMO_MODE=live
